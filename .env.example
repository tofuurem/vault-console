# Existing external Docker network shared by Caddy, Vault, and Vault Console.
VAULT_DOCKER_NETWORK=caddy_net

# Internal URL resolvable from caddy_net. Do not add /v1 or a trailing slash.
VAULT_UPSTREAM=http://vault:8200

# UI uses the same browser origin and the default userpass/ mount by default.
# Enable only when operators must override deployment details on the login page.
VAULT_UI_ALLOW_CUSTOM_ADDRESS=false
VAULT_UI_USERPASS_MOUNT=userpass
VAULT_UI_ALLOW_CUSTOM_USERPASS_MOUNT=false

# Safe local bind by default. Use 0.0.0.0 only for intentional direct exposure.
VAULT_CONSOLE_BIND=127.0.0.1
VAULT_CONSOLE_PORT=8080
VAULT_CONSOLE_IMAGE=vault-console:local

# Optional for npm run dev when calling a separate-origin Vault directly.
# VITE_VAULT_ADDR=https://vault.example.com
