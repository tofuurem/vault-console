# High-privilege operator policy for the default userpass/ mount.
# Review and narrow it for your environment before use.

path "sys/internal/ui/mounts" {
  capabilities = ["read"]
}

# Optional but recommended: without this path the UI remains usable and lets
# each Vault API call decide, but it cannot disable forbidden actions in advance.
path "sys/capabilities-self" {
  capabilities = ["update"]
}

# Enabling a secrets engine is root-protected and requires sudo in addition to
# create/update. Narrow this glob when operators may create mounts only below a
# controlled prefix, for example sys/mounts/team/*.
path "sys/mounts/*" {
  capabilities = ["create", "update", "sudo"]
}

path "sys/auth" {
  capabilities = ["read"]
}

path "sys/policy" {
  capabilities = ["read", "list"]
}

path "sys/policy/*" {
  capabilities = ["create", "read", "update", "delete"]
}

path "identity/group/id" {
  capabilities = ["list"]
}

path "identity/group/id/*" {
  capabilities = ["read", "update"]
}

path "identity/lookup/entity" {
  capabilities = ["update"]
}

path "identity/entity/name/*" {
  capabilities = ["read"]
}

path "identity/entity" {
  capabilities = ["update"]
}

path "identity/entity/id/*" {
  capabilities = ["read", "delete"]
}

path "identity/entity-alias" {
  capabilities = ["update"]
}

path "identity/entity-alias/id/*" {
  capabilities = ["delete"]
}

# Repeat these two stanzas for every userpass auth mount the UI may manage.
path "auth/userpass/users" {
  capabilities = ["list"]
}

path "auth/userpass/users/*" {
  capabilities = ["create", "read", "update", "delete"]
}
